# ─────────────────────────────────────────────────────────────────
# .env.example — Template for non-secret configuration
#
# Copy this to .env and fill in values.
#
# SECURITY: Institution credentials (NFCU, Chase, Fidelity, etc.)
# are stored in Windows Credential Manager — NOT in this file.
#
# First-time credential setup (run in an elevated terminal):
#   python backend/credential_broker.py --store nfcu
#   python backend/credential_broker.py --store chase
#   python backend/credential_broker.py --store fidelity
#   python backend/credential_broker.py --store tsp
#   python backend/credential_broker.py --store acorns
#
# Verify stored credentials:
#   python backend/credential_broker.py --list
#
# ─────────────────────────────────────────────────────────────────

# AI Backstop — Gemini API key (free tier: 15 RPM, 1M tokens/day)
# Get one at: https://aistudio.google.com/app/apikey
# This is an API key (not a user password) — safe to store in .env
GEMINI_API_KEY=your-gemini-api-key

# Chrome Automation Profile directory (separate from your daily Chrome)
# See extractors/chrome_cdp.py for first-time setup instructions
CHROME_AUTOMATION_PROFILE=C:\ChromeAutomationProfile
